# ─── Retell AI ────────────────────────────────────────────────────────────────
# Sign up at retellai.com → Dashboard → API Keys
RETELL_API_KEY=

# ─── Twilio ───────────────────────────────────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── AI Model ─────────────────────────────────────────────────────────────────
# Gemini Flash 2.5 — fast, cheap, and we have credits
# Get your API key at: aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Telegram ─────────────────────────────────────────────────────────────────
# The bot that pings the owner when an order comes in
# Create via BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (owner gets the order pings)
TELEGRAM_CHAT_ID=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
