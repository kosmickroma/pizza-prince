# ─── Retell AI ────────────────────────────────────────────────────────────────
# Sign up at retellai.com → Dashboard → API Keys
RETELL_API_KEY=

# ─── Twilio ───────────────────────────────────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── AI Model ─────────────────────────────────────────────────────────────────
# Claude Haiku — get your API key at: platform.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── Telegram ─────────────────────────────────────────────────────────────────
# The bot that pings the owner when an order comes in
# Create via BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (owner gets the order pings)
TELEGRAM_CHAT_ID=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
